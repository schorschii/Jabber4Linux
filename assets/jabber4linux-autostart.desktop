[Desktop Entry]
Type=Application
Name=Jabber4Linux
Exec=bash -c "jabber4linux --hidden >> ~/jabber4linux.log"
Terminal=false
Icon=/usr/share/jabber4linux/jabber4linux/assets/tux-phone.svg
Categories=Application;Utility
Comment=Unofficial Linux implementation of Cisco Jabber softphone

# execute `update-desktop-database` after copying into /etc/xdg/autostart
